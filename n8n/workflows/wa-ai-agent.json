        "jsCode": "const base = $('Normalizar Payload').first().json;\nconst msg  = $input.first().json || {};\n\n// Detecta content_type pela extensão da URL se o banco retornou 'text'\nlet contentType = msg.content_type || base.content_type || 'text';\nconst url = msg.media_url || base.media_url || '';\nif (url && contentType === 'text') {\n  const ext = url.split('?')[0].toLowerCase().split('.').pop();\n  if (['ogg','opus','mp3','m4a','wav','aac','oga'].includes(ext)) contentType = 'audio';\n  else if (['mp4','avi','mov','mkv','webm'].includes(ext))         contentType = 'video';\n  else if (['jpg','jpeg','png','gif','webp','heic'].includes(ext)) contentType = 'image';\n  else if (['pdf','doc','docx','xls','xlsx','ppt'].includes(ext))  contentType = 'document';\n}\n\nreturn [{ json: {\n  ...base,\n  content_type:       contentType,\n  media_url:          msg.media_url           || base.media_url          || null,\n  transcription_text: msg.transcription_text  || base.transcription_text || null,\n  media_duration_sec: msg.media_duration_sec  || base.media_duration_sec || null,\n  content_text:       msg.content_text        || base.content_text       || '',\n  file_name:          null,\n  customer_name:      msg.customer_name       || base.customer_name      || 'Cliente',\n  customer_phone:     msg.customer_phone      || base.customer_phone     || '',\n}}];\n"
      },
